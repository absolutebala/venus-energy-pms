# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key — NEVER expose this on the client. Used ONLY in API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — used for redirects (change to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
